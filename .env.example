# Copy this file to .env for local dev, and set the same variables in Railway.
# These are the crypto wallet addresses buyers will send payment to.
# Replace the placeholders with YOUR real wallet addresses.

STORE_NAME=PokéVault
SUPPORT_EMAIL=you@example.com

# Bitcoin
BTC_ADDRESS=bc1q-your-btc-address
# Tether (ERC-20, Ethereum network)
USDT_ADDRESS=0x-your-eth-address
# USD Coin (ERC-20, Ethereum network)
USDC_ADDRESS=0x-your-eth-address
# Solana
SOL_ADDRESS=your-solana-address

# Optional: port (Railway sets this automatically)
# PORT=3000
